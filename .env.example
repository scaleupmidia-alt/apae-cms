# ─── Desenvolvimento local (SQLite + disco local) ───
# Basta um segredo qualquer e o caminho do arquivo SQLite.
PAYLOAD_SECRET=troque-por-um-segredo-forte
DATABASE_URI=file:./apae-cms.db

# ─── Produção (Vercel) — preencher com os valores das contas ───
# DATABASE_URI: string de conexão do Vercel Postgres (começa com "postgres://...").
#   Quando começar com "postgres", o painel usa Postgres automaticamente.
# DATABASE_URI=postgres://USUARIO:SENHA@HOST/DB?sslmode=require
#
# PAYLOAD_SECRET: segredo forte e único (ex.: gerado por gerenciador de senhas).
# PAYLOAD_SECRET=...
#
# BLOB_READ_WRITE_TOKEN: token do Vercel Blob (armazenamento de imagens).
#   Quando presente, as imagens vão para o Vercel Blob em vez do disco local.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
